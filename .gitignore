# ===========================
# Unity
# ===========================

# Library folder (regenerated)
unity/*/[Ll]ibrary/
unity/*/[Tt]emp/
unity/*/[Oo]bj/
unity/*/[Bb]uild/
unity/*/[Bb]uilds/
unity/*/[Ll]ogs/
unity/*/[Uu]ser[Ss]ettings/

# MemoryCaptures
unity/*/[Mm]emoryCaptures/

# Recordings
unity/*/[Rr]ecordings/

# Asset meta data (sometimes)
unity/*/*.pidb.meta
unity/*/*.pdb.meta
unity/*/*.mdb.meta

# Unity3D generated
unity/*/*.csproj
unity/*/*.unityproj
unity/*/*.sln
unity/*/*.suo
unity/*/*.tmp
unity/*/*.user
unity/*/*.userprefs
unity/*/*.pidb
unity/*/*.booproj
unity/*/*.svd
unity/*/*.pdb
unity/*/*.mdb
unity/*/*.opendb
unity/*/*.VC.db

# Unity profiler
unity/*/*.apk
unity/*/*.aab
unity/*/*.unitypackage
unity/*/*.unitypackage.meta

# Crashlytics
unity/*/crashlytics-build.properties

# Builds (keep out of version control)
unity/*/*.apk
unity/*/*.aab
unity/*/*.ipa

# ===========================
# Node.js (Relay Server)
# ===========================

server/node_modules/
server/.env
server/.env.local
server/.env.*.local
server/npm-debug.log*
server/yarn-debug.log*
server/yarn-error.log*
server/.pnpm-debug.log*
server/dist/
server/coverage/

